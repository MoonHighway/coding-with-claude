# Vercel AI Gateway — one key, every model.
# Get yours: https://vercel.com/dashboard → AI Gateway → API Keys
AI_GATEWAY_API_KEY=vck_your_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Route Claude Code through the AI Gateway
# ─────────────────────────────────────────────────────────────────────────────
# Easiest: run ./setup.sh — it sets all of this up and verifies it for you.
#
# Manual: add these to your shell profile (~/.zshrc or ~/.bashrc), NOT just .env,
# because Claude Code reads them from your environment:
#
#   export ANTHROPIC_BASE_URL="https://ai-gateway.vercel.sh"
#   export ANTHROPIC_AUTH_TOKEN="$AI_GATEWAY_API_KEY"
#   export ANTHROPIC_API_KEY=""    # ← MUST be empty: Claude Code checks this FIRST,
#                                  #    and a non-empty value silently wins over the
#                                  #    gateway token above.
#   export ANTHROPIC_MODEL="anthropic/claude-sonnet-4.6"   # optional: pin the model
#
# Then open a new terminal (or `source` your profile) and run `claude`.
# Swap models anytime with /model inside Claude Code.
